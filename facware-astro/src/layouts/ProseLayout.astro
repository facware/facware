---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  pageTitle: string;
  pageSubtitle: string;
  breadcrumbLabel: string;
}

const {
  title,
  description,
  canonicalURL,
  pageTitle,
  pageSubtitle,
  breadcrumbLabel,
} = Astro.props;
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL}>
  <!-- Page hero with breadcrumb -->
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <i class="fas fa-chevron-right" aria-hidden="true" style="font-size:10px"></i>
        <span aria-current="page">{breadcrumbLabel}</span>
      </nav>
      <h1>{pageTitle}</h1>
      <p>{pageSubtitle}</p>
    </div>
  </div>

  <!-- Prose content -->
  <section class="prose-section">
    <div class="container">
      <div class="prose">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .prose-section {
    padding: clamp(48px, 7vw, 80px) 0;
  }

  .prose {
    max-width: 780px;
    margin: 0 auto;
  }

  .prose h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #1a1a2e;
    margin: 2.5rem 0 0.75rem;
    padding-top: 0.5rem;
    border-top: 2px solid #e2e8f0;
  }

  .prose h2:first-child {
    margin-top: 0;
    border-top: none;
  }

  .prose h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: #1a1a2e;
    margin: 1.5rem 0 0.5rem;
  }

  .prose p {
    color: #3d4663;
    margin-bottom: 1rem;
    line-height: 1.75;
  }

  .prose ul,
  .prose ol {
    color: #3d4663;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose li {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  .prose a { color: #086AD8; }
  .prose a:hover { color: #065bb8; }
  .prose strong { color: #1a1a2e; }

  .prose .last-updated {
    display: inline-block;
    background: #f0f6ff;
    color: #086AD8;
    font-size: 13px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 2rem;
  }

  .prose .highlight-box {
    background: #f0f6ff;
    border-left: 4px solid #086AD8;
    padding: 16px 20px;
    border-radius: 0 8px 8px 0;
    margin: 1.5rem 0;
  }

  .prose .highlight-box p {
    margin: 0;
    color: #1a1a2e;
  }
</style>
