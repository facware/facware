---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const cookieBannerKey = 'facware_cookie_consent_v1';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  ogDescription?: string;
  preloadHeroImage?: boolean;
}

const {
  title,
  description,
  canonicalURL = Astro.url.href,
  ogImage = 'https://facware.com/assets/images/facware/og-image.jpg',
  ogDescription = description,
  preloadHeroImage = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalURL}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={ogDescription}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:site_name" content="Facware">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={ogDescription}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Favicon -->
  <link rel="icon" href="/assets/images/facware/favicon_facware.png" type="image/png">

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- LCP hero image preload (index page only) -->
  {preloadHeroImage && (
    <link rel="preload" as="image" href="/assets/images/facware/business_solutions_home.jpg">
  )}

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- FontAwesome (served from public/assets/) -->
  <link rel="stylesheet" href="/assets/css/vendor/fontawesome-all.min.css">

  <!-- Page-specific head additions (critical CSS, preloads, etc.) -->
  <slot name="head" />

  <!-- Critical above-fold CSS — inlined to eliminate render-blocking -->
  <style is:inline>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth;font-size:16px}
    body{font-family:'Inter',system-ui,-apple-system,sans-serif;color:#1a1a2e;background:#fff;line-height:1.65;-webkit-font-smoothing:antialiased}
    .container{width:100%;max-width:1200px;margin:0 auto;padding:0 clamp(16px,4vw,48px)}
    .site-header{position:sticky;top:0;z-index:100;background:#fff;border-bottom:1px solid #e2e8f0}
    .top-bar{background:#1a1a2e;color:rgba(255,255,255,.9);font-size:13px;padding:9px clamp(16px,4vw,48px);text-align:center}
    .top-bar a{color:#7bc4f8;text-decoration:none;font-weight:500}
    .top-bar strong{color:#fff}
    .nav-wrap{display:flex;align-items:center;justify-content:space-between;padding:14px 0;gap:16px}
    .btn{display:inline-flex;align-items:center;gap:6px;padding:14px 28px;border-radius:8px;font-size:15px;font-weight:600;text-decoration:none;cursor:pointer;border:2px solid transparent;line-height:1;white-space:nowrap;transition:.22s ease}
    .btn-primary{background:#086AD8;color:#fff;border-color:#086AD8}
    .btn-primary:hover{background:#065bb8;border-color:#065bb8;transform:translateY(-1px);color:#fff}
    .btn-outline-white{background:transparent;color:#fff;border-color:rgba(255,255,255,.55)}
    .btn-outline-white:hover{background:rgba(255,255,255,.12)}
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />

  <aside class="cookie-banner" id="cookie-banner" role="dialog" aria-live="polite" aria-label="Cookie consent" hidden>
    <p>
      We use essential cookies for site functionality and optional analytics cookies only with your consent.
      <a href="/privacy-policy.html">Learn more</a>.
    </p>
    <div class="cookie-banner-actions">
      <button type="button" class="btn btn-outline-cookie" id="cookie-reject">Only essential</button>
      <button type="button" class="btn btn-primary" id="cookie-accept">Accept all</button>
    </div>
  </aside>

  <!-- Scroll-to-top button -->
  <a href="#main-content" class="scroll-top" id="scroll-top" aria-label="Scroll back to top">
    <i class="fas fa-chevron-up" aria-hidden="true"></i>
  </a>

  <script define:vars={{ cookieBannerKey }}>
    const cookieKey = cookieBannerKey;
    const appWindow = /** @type {any} */ (window);

    const readConsent = () => {
      try {
        return localStorage.getItem(cookieKey);
      } catch {
        return null;
      }
    };

    const writeConsent = (value) => {
      try {
        localStorage.setItem(cookieKey, value);
      } catch {
        // Some browsers/privacy modes can block storage. UI should still continue.
      }
    };

    const applyConsent = (consent) => {
      appWindow.facwareConsent = {
        necessary: true,
        analytics: consent === 'all',
      };
      window.dispatchEvent(new CustomEvent('facware:consent-updated', { detail: appWindow.facwareConsent }));
    };

    const initCookieBanner = () => {
      const banner = document.getElementById('cookie-banner');
      const acceptBtn = document.getElementById('cookie-accept');
      const rejectBtn = document.getElementById('cookie-reject');
      const storedConsent = readConsent();

      if (!banner) return;

      if (!storedConsent) {
        banner.hidden = false;
      } else {
        applyConsent(storedConsent);
        banner.hidden = true;
      }

      if (acceptBtn) {
        acceptBtn.addEventListener('click', () => {
          writeConsent('all');
          applyConsent('all');
          banner.hidden = true;
        });
      }

      if (rejectBtn) {
        rejectBtn.addEventListener('click', () => {
          writeConsent('essential');
          applyConsent('essential');
          banner.hidden = true;
        });
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCookieBanner, { once: true });
    } else {
      initCookieBanner();
    }

    // Scroll-to-top visibility
    const sb = document.getElementById('scroll-top');
    if (sb) {
      window.addEventListener('scroll', () => {
        sb.classList.toggle('visible', window.scrollY > 400);
      }, { passive: true });
    }

    // Header shadow on scroll
    const sh = document.querySelector('.site-header');
    if (sh) {
      window.addEventListener('scroll', () => {
        sh.classList.toggle('scrolled', window.scrollY > 10);
      }, { passive: true });
    }

    // IntersectionObserver scroll animations
    if ('IntersectionObserver' in window) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.card, .step-item, .stat-item, .results-list li').forEach(el => {
        el.classList.add('animate-on-scroll');
        obs.observe(el);
      });
    }
  </script>

  <style is:inline>
    .cookie-banner[hidden]{display:none}
    .cookie-banner{
      position:fixed;
      left:16px;
      right:16px;
      bottom:16px;
      z-index:1200;
      background:#111827;
      color:#fff;
      border:1px solid rgba(255,255,255,.12);
      border-radius:12px;
      padding:16px;
      display:flex;
      gap:14px;
      align-items:center;
      justify-content:space-between;
      box-shadow:0 12px 30px rgba(0,0,0,.3);
      max-width:860px;
      margin:0 auto;
    }
    .cookie-banner p{font-size:14px;line-height:1.45;margin:0;max-width:620px}
    .cookie-banner a{color:#8fd0ff}
    .cookie-banner-actions{display:flex;gap:10px;flex-wrap:wrap}
    .btn-outline-cookie{background:transparent;color:#fff;border-color:rgba(255,255,255,.45)}
    .btn-outline-cookie:hover{background:rgba(255,255,255,.12)}
    @media (max-width: 760px){
      .cookie-banner{flex-direction:column;align-items:flex-start}
    }

    /* WhatsApp floating button */
    .wa-float{
      position:fixed;
      right:16px;
      bottom:90px;
      z-index:1100;
      display:flex;
      align-items:center;
      gap:10px;
      text-decoration:none;
    }
    .wa-float-bubble{
      background:#25D366;
      color:#fff;
      font-size:13px;
      font-weight:600;
      padding:8px 14px;
      border-radius:24px;
      box-shadow:0 4px 14px rgba(0,0,0,.25);
      white-space:nowrap;
      opacity:0;
      transform:translateX(8px);
      transition:opacity .25s,transform .25s;
      pointer-events:none;
    }
    .wa-float:hover .wa-float-bubble,
    .wa-float:focus-visible .wa-float-bubble{
      opacity:1;
      transform:translateX(0);
    }
    .wa-float-icon{
      width:54px;
      height:54px;
      background:#25D366;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:0 4px 16px rgba(37,211,102,.45);
      flex-shrink:0;
      transition:transform .2s;
    }
    .wa-float:hover .wa-float-icon,
    .wa-float:focus-visible .wa-float-icon{transform:scale(1.08)}
    .wa-float-icon svg{width:28px;height:28px;fill:#fff}
  </style>

  <!-- Chatbot widget (ChatbotGen) -->
  <script src="https://www.chatbotgen.com/v2/chatbots/helpbot-clunu5o/script.js" defer></script>

  <!-- WhatsApp Business floating button -->
  <a
    href="https://wa.me/526142542471?text=Hi%2C%20I%20found%20your%20website%20and%20I%27d%20like%20to%20learn%20more%20about%20your%20services."
    class="wa-float"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Chat with us on WhatsApp"
  >
    <span class="wa-float-bubble" aria-hidden="true">Chat on WhatsApp</span>
    <span class="wa-float-icon">
      <!-- WhatsApp logo SVG (official brand asset) -->
      <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M16 .8C7.6.8.8 7.6.8 16c0 2.7.7 5.3 2 7.6L.8 31.2l7.8-2c2.2 1.2 4.7 1.8 7.4 1.8 8.4 0 15.2-6.8 15.2-15.2S24.4.8 16 .8zm0 27.8c-2.4 0-4.7-.6-6.7-1.8l-.5-.3-4.6 1.2 1.2-4.5-.3-.5C3.8 20.7 3.2 18.4 3.2 16 3.2 9.4 8.6 4 16 4s12.8 5.4 12.8 12S22.6 28.6 16 28.6zm7-9.1c-.4-.2-2.3-1.1-2.6-1.2-.4-.1-.6-.2-.9.2-.3.4-1 1.2-1.3 1.5-.2.3-.5.3-.9.1-.4-.2-1.7-.6-3.2-2-1.2-1-2-2.3-2.2-2.7-.2-.4 0-.6.2-.8l.6-.7c.2-.2.2-.4.4-.6.1-.2.1-.4 0-.6-.1-.2-.9-2.1-1.2-2.9-.3-.8-.6-.7-.9-.7h-.7c-.3 0-.7.1-1 .5-.4.4-1.4 1.3-1.4 3.2s1.4 3.7 1.6 4c.2.2 2.8 4.3 6.8 6 1 .4 1.7.6 2.3.8.9.3 1.8.2 2.4.1.7-.1 2.3-.9 2.6-1.8.3-.9.3-1.6.2-1.8-.1-.2-.3-.3-.7-.5z"/>
      </svg>
    </span>
  </a>
</body>
</html>
