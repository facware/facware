---
// ContactInfo.astro — dark sidebar with email, location, badge, social links
---

<aside class="contact-info" aria-label="Contact information">
  <p class="contact-info-eyebrow">Get in touch</p>
  <h2 id="contact-page-heading">Free 30-min operations assessment</h2>
  <p class="contact-info-lead">We'll map your current bottlenecks, quantify the cost, and show you the highest-ROI fix — whether or not we end up working together.</p>

  <ul class="info-items" role="list">
    <li class="info-item">
      <div class="info-icon"><i class="fas fa-envelope" aria-hidden="true"></i></div>
      <div>
        <strong>Contact</strong>
        <a href="/contact.html#contact-form">Use secure contact form</a>
      </div>
    </li>
    <li class="info-item">
      <div class="info-icon"><i class="fas fa-map-marker-alt" aria-hidden="true"></i></div>
      <div>
        <strong>Location</strong>
        <span>Chihuahua, Chihuahua, México<br>Serving Mexico &amp; US Southwest</span>
      </div>
    </li>
    <li class="info-item">
      <div class="info-icon"><i class="fas fa-clock" aria-hidden="true"></i></div>
      <div>
        <strong>Response time</strong>
        <span>Within 1 business day</span>
      </div>
    </li>
  </ul>

  <hr class="info-divider">

  <div class="info-badge">
    <i class="fas fa-shield-alt" aria-hidden="true"></i>
    No commitment. No pitch deck.
  </div>

  <div class="info-social" aria-label="Follow us">
    <a href="https://www.facebook.com/facware" target="_blank" rel="noopener noreferrer" aria-label="Facware on Facebook">
      <i class="fab fa-facebook-f" aria-hidden="true"></i>
    </a>
    <a href="https://www.linkedin.com/company/18322494/" target="_blank" rel="noopener noreferrer" aria-label="Facware on LinkedIn">
      <i class="fab fa-linkedin-in" aria-hidden="true"></i>
    </a>
  </div>
</aside>
