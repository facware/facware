# Web3Forms access key — get yours free at https://app.web3forms.com/
# The PUBLIC_ prefix makes this available in client-side scripts
PUBLIC_WEB3FORMS_KEY=your-key-from-app.web3forms.com

# Cloudflare Turnstile site key — get yours at https://dash.cloudflare.com/?to=/:account/turnstile
# Leave empty to disable Turnstile widget (form still works with honeypot protection)
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Cloudflare Turnstile secret key — get yours at https://dash.cloudflare.com/?to=/:account/turnstile
# This should be kept secret and only used in server-side code  to verify Turnstile responses
SECRET_TURNSTILE_SITE_KEY=your-turnstile-secret-key