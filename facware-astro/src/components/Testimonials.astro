---
// Testimonials.astro — auto-advance carousel with touch, keyboard, and pause-on-hover
---

<section class="section" aria-labelledby="testimonials-heading">
  <div class="container">
    <header class="section-header text-center">
      <p class="section-eyebrow">Client Proof</p>
      <h2 id="testimonials-heading">What clients say after we <span class="text-primary">ship their system</span></h2>
    </header>
    <div class="testimonials" role="region" aria-label="Client testimonials">
      <div class="testimonials-track" id="testimonials-track">
        <article class="testimonial" role="group" aria-label="Testimonial 1 of 4">
          <div class="testimonial-stars" aria-label="5 out of 5 stars" role="img">
            <i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i>
          </div>
          <blockquote class="testimonial-quote">Facware mapped our entire ERP-to-warehouse workflow, automated the reconciliation, and had it live in 6 weeks. We cut our ops overhead by nearly half — it paid for itself in the first quarter.</blockquote>
          <div class="testimonial-author">
            <img src="/assets/images/testimonial/Facware-testimonial-avata-02-90x90.webp" width="48" height="48" alt="Javier Domínguez" loading="lazy">
            <span class="author-name">Javier Domínguez</span>
          </div>
        </article>
        <article class="testimonial" role="group" aria-label="Testimonial 2 of 4">
          <div class="testimonial-stars" aria-label="5 out of 5 stars" role="img">
            <i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i>
          </div>
          <blockquote class="testimonial-quote">What impressed me most was how they scoped the project around a specific outcome, not hours. We knew exactly what we'd get and when. No surprises, no scope creep — just delivery.</blockquote>
          <div class="testimonial-author">
            <img src="/assets/images/testimonial/Facware-testimonial-avata-03-90x90.webp" width="48" height="48" alt="Monica Blews" loading="lazy">
            <span class="author-name">Monica Blews</span>
          </div>
        </article>
        <article class="testimonial" role="group" aria-label="Testimonial 3 of 4">
          <div class="testimonial-stars" aria-label="5 out of 5 stars" role="img">
            <i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i>
          </div>
          <blockquote class="testimonial-quote">We'd tried two agencies before Facware. Both times the project dragged, scope crept, and we got a half-finished product. With Facware, it shipped clean. One team, one accountable partner.</blockquote>
          <div class="testimonial-author">
            <img src="/assets/images/testimonial/Facware-testimonial-avata-04-90x90.webp" width="48" height="48" alt="Abbie Ferguson" loading="lazy">
            <span class="author-name">Abbie Ferguson</span>
          </div>
        </article>
        <article class="testimonial" role="group" aria-label="Testimonial 4 of 4">
          <div class="testimonial-stars" aria-label="5 out of 5 stars" role="img">
            <i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i><i class="fas fa-star" aria-hidden="true"></i>
          </div>
          <blockquote class="testimonial-quote">The integration between our systems that we thought would take months was done in 3 weeks. The team already understood our cross-border workflow context from day one — no lengthy onboarding required.</blockquote>
          <div class="testimonial-author">
            <img src="/assets/images/testimonial/Facware-testimonial-avata-01-90x90.webp" width="48" height="48" alt="Diego Navarro" loading="lazy">
            <span class="author-name">Diego Navarro</span>
          </div>
        </article>
      </div>
      <div class="testimonials-controls" role="group" aria-label="Testimonial navigation">
        <button class="tc-btn" id="tc-prev" aria-label="Previous testimonial"><i class="fas fa-chevron-left" aria-hidden="true"></i></button>
        <div class="tc-dots" role="tablist" id="tc-dots"></div>
        <button class="tc-btn" id="tc-next" aria-label="Next testimonial"><i class="fas fa-chevron-right" aria-hidden="true"></i></button>
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('testimonials-track');
  const dotsWrap = document.getElementById('tc-dots');
  const prevBtn = document.getElementById('tc-prev');
  const nextBtn = document.getElementById('tc-next');

  if (track && dotsWrap && prevBtn && nextBtn) {
    const slides = track.querySelectorAll('.testimonial');
    let current = 0;
    let timer;

    // Build dot navigation
    slides.forEach((_, i) => {
      const d = document.createElement('button');
      d.className = 'tc-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('role', 'tab');
      d.setAttribute('aria-label', 'Go to testimonial ' + (i + 1));
      d.setAttribute('aria-selected', String(i === 0));
      d.addEventListener('click', () => goTo(i));
      dotsWrap.appendChild(d);
    });

    function goTo(i) {
      current = (i + slides.length) % slides.length;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dotsWrap.querySelectorAll('.tc-dot').forEach((d, j) => {
        d.classList.toggle('active', j === current);
        d.setAttribute('aria-selected', String(j === current));
      });
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    function start() { timer = setInterval(() => goTo(current + 1), 6000); }
    function stop() { clearInterval(timer); }
    start();

    const region = track.closest('[role="region"]') || track.parentElement;
    region.addEventListener('mouseenter', stop);
    region.addEventListener('mouseleave', start);
    region.addEventListener('focusin', stop);
    region.addEventListener('focusout', start);

    let sx = 0;
    track.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', e => {
      const d = sx - e.changedTouches[0].clientX;
      if (Math.abs(d) > 48) goTo(d > 0 ? current + 1 : current - 1);
    });
  }
</script>
